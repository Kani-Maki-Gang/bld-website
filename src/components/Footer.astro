---
---

<footer class="border-t border-zinc-800 bg-zinc-900">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 md:grid-cols-3">
      <div class="md:col-span-1">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5">
          <img src={import.meta.env.BASE_URL + 'logo_no_bg.png'} alt="Bld logo" class="size-7" />
          <span class="text-sm font-semibold tracking-tight text-white">bld</span>
        </a>
        <p class="mt-3 text-sm text-zinc-500">
          Simple and blazingly fast CI/CD.<br />
          Run pipelines anywhere.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
          Resources
        </h4>
        <ul class="mt-3 space-y-2">
          {
            [
              ['Documentation', import.meta.env.BASE_URL + 'docs/', false],
              ['Getting Started', import.meta.env.BASE_URL + 'docs/getting-started/', false],
              ['CLI Reference', import.meta.env.BASE_URL + 'docs/cli/', false],
              ['Releases', 'https://github.com/Kani-Maki-Gang/bld/releases', true],
            ].map(([label, href, external]) => (
              <li>
                <a
                  href={href}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                  class="text-sm text-zinc-400 transition-colors duration-150 hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
          Community
        </h4>
        <ul class="mt-3 space-y-2">
          {
            [
              ['GitHub', 'https://github.com/Kani-Maki-Gang/bld'],
              [
                'Issues',
                'https://github.com/Kani-Maki-Gang/bld/issues',
              ],
              [
                'GitHub Action',
                'https://github.com/Kani-Maki-Gang/bld-github-action',
              ],
            ].map(([label, href]) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-zinc-400 transition-colors duration-150 hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-zinc-800 pt-6 flex items-center justify-between">
      <p class="text-xs text-zinc-600">
        &copy; {new Date().getFullYear()} Kani-Maki-Gang. Released under the MIT License.
      </p>
      <a
        href="https://github.com/Kani-Maki-Gang/bld"
        target="_blank"
        rel="noopener noreferrer"
        class="text-zinc-600 transition-colors duration-150 hover:text-zinc-400"
        aria-label="GitHub"
      >
        <i class="iconoir-github-circle text-lg"></i>
      </a>
    </div>
  </div>
</footer>
