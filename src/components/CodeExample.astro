---
import { Code } from 'astro:components';

const pipelineExample = `name: build-and-test
version: 2

runs_on:
  image: node:lts
  pull: true

variables:
  branch: main

artifacts:
  - method: get
    from: /app/dist
    to: ./dist
    after: test

jobs:
  install:
    - working_dir: /app
      exec:
        - git clone -b \${{branch}} https://github.com/your-org/app .
        - npm install

  test:
    needs:
      - install
    - working_dir: /app
      exec:
        - npm run test
        - npm run build`;
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-white">
          Write pipelines in YAML.<br />Run them anywhere.
        </h2>
        <p class="mt-4 text-base text-zinc-400">
          Pipeline syntax is versioned independently from the tool itself.
          Upgrade at your own pace — existing pipelines keep working.
        </p>
        <ul class="mt-6 space-y-3">
          {
            [
              ['iconoir-check-circle', 'Version 2 with parallel job support'],
              ['iconoir-check-circle', 'Variables and environment configuration'],
              ['iconoir-check-circle', 'Artifact management between environments'],
              ['iconoir-check-circle', 'Cron scheduling built in'],
            ].map(([icon, text]) => (
              <li class="flex items-center gap-2.5 text-sm text-zinc-300">
                <i class={`${icon} text-violet-400 text-base shrink-0`} />
                {text}
              </li>
            ))
          }
        </ul>
        <a
          href={import.meta.env.BASE_URL + 'docs/pipelines/'}
          class="mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-violet-400 underline-offset-2 hover:text-violet-300 hover:underline transition-colors duration-150"
        >
          Read the pipeline docs
          <i class="iconoir-arrow-right text-base"></i>
        </a>
      </div>

      <Code class="overflow-auto rounded-xl p-4 text-sm" code={pipelineExample} lang="yaml" theme="github-dark" />
    </div>
  </div>
</section>
