---
interface Props {
  type?: 'note' | 'warning' | 'tip';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
  note: {
    icon: 'iconoir-info-circle',
    defaultTitle: 'Note',
    border: 'border-violet-500',
    bg: 'bg-violet-500/10',
    iconColor: 'text-violet-400',
    titleColor: 'text-violet-300',
  },
  warning: {
    icon: 'iconoir-warning-triangle',
    defaultTitle: 'Warning',
    border: 'border-amber-500',
    bg: 'bg-amber-500/10',
    iconColor: 'text-amber-400',
    titleColor: 'text-amber-300',
  },
  tip: {
    icon: 'iconoir-check-circle',
    defaultTitle: 'Tip',
    border: 'border-green-500',
    bg: 'bg-green-500/10',
    iconColor: 'text-green-400',
    titleColor: 'text-green-300',
  },
};

const c = config[type];
const label = title ?? c.defaultTitle;
---

<div class:list={['not-prose my-5 flex gap-3 rounded-r-lg border-l-4 px-4 py-3', c.border, c.bg]}>
  <i class:list={['mt-0.5 shrink-0 text-base', c.icon, c.iconColor]}></i>
  <div class="min-w-0 text-sm leading-relaxed text-zinc-300">
    <p class:list={['mb-1 font-semibold', c.titleColor]}>{label}</p>
    <slot />
  </div>
</div>
