---
import { docsNav, isNavSubSection } from '../../data/docs-nav';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

// Find matching section or sub-section
type CardItem = { title: string; href: string; description?: string };
let cards: CardItem[] = [];

for (const section of docsNav) {
  if (section.slug === slug) {
    cards = section.items.map((item) => ({
      title: item.title,
      href: item.href,
      description: item.description,
    }));
    break;
  }
  for (const item of section.items) {
    if (isNavSubSection(item) && item.slug === slug) {
      cards = item.items.map((sub) => ({
        title: sub.title,
        href: sub.href,
        description: sub.description,
      }));
      break;
    }
  }
}
---

{cards.length > 0 && (
  <div class="not-prose mt-10 border-t border-zinc-800 pt-8">
    <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-zinc-500">In this section</p>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group rounded-xl border border-zinc-800 px-4 py-4 transition-colors duration-150 hover:border-violet-500/50 hover:bg-violet-500/5"
        >
          <div class="flex items-center justify-between">
            <p class="font-medium text-white transition-colors duration-150 group-hover:text-violet-300">
              {card.title}
            </p>
            <i class="iconoir-arrow-right text-sm text-zinc-600 transition-colors duration-150 group-hover:text-violet-400"></i>
          </div>
          {card.description && (
            <p class="mt-1 text-sm text-zinc-500">{card.description}</p>
          )}
        </a>
      ))}
    </div>
  </div>
)}
