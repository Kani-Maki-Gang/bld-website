---
import { docsNav, isNavSubSection } from '../../data/docs-nav';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string): boolean {
  const normalized = currentPath.endsWith('/') ? currentPath : currentPath + '/';
  return normalized === href;
}

function sectionContainsActive(href: string, items: any[]): boolean {
  if (isActive(href)) return true;
  for (const item of items) {
    if (isActive(item.href)) return true;
    if (isNavSubSection(item) && sectionContainsActive(item.href, item.items)) return true;
  }
  return false;
}
---

<nav class="py-6 pr-4 text-sm">
  <ul class="space-y-0.5">
    {docsNav.map((section) => {
      const hasChildren = section.items.length > 0;
      const sectionActive = sectionContainsActive(section.href, section.items);

      if (!hasChildren) {
        return (
          <li>
            <a
              href={section.href}
              class:list={[
                'flex items-center rounded-lg px-3 py-1.5 font-medium transition-colors duration-150',
                isActive(section.href)
                  ? 'bg-violet-500/15 text-violet-300'
                  : 'text-zinc-400 hover:bg-zinc-800 hover:text-white',
              ]}
            >
              {section.title}
            </a>
          </li>
        );
      }

      return (
        <li>
          <details open={sectionActive || undefined} class="group">
            <summary class:list={[
              'flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-1.5 font-medium transition-colors duration-150 select-none',
              sectionActive ? 'text-white' : 'text-zinc-400 hover:bg-zinc-800 hover:text-white',
            ]}>
              <a
                href={section.href}
                class:list={[
                  'flex-1',
                  isActive(section.href) ? 'text-violet-300' : '',
                ]}
                onclick="event.stopPropagation()"
              >
                {section.title}
              </a>
              <i class="iconoir-nav-arrow-down text-xs transition-transform duration-150 group-open:rotate-180 ml-1 shrink-0"></i>
            </summary>
            <ul class="mt-0.5 ml-3 space-y-0.5 border-l border-zinc-800 pl-3">
              {section.items.map((item) => {
                if (isNavSubSection(item)) {
                  const subActive = sectionContainsActive(item.href, item.items);
                  return (
                    <li>
                      <details open={subActive || undefined} class="group/sub">
                        <summary class:list={[
                          'flex cursor-pointer list-none items-center justify-between rounded-lg px-2 py-1.5 text-xs font-semibold uppercase tracking-wider transition-colors duration-150 select-none',
                          subActive ? 'text-zinc-300' : 'text-zinc-500 hover:text-zinc-300',
                        ]}>
                          <a
                            href={item.href}
                            class:list={[isActive(item.href) ? 'text-violet-300' : '']}
                            onclick="event.stopPropagation()"
                          >
                            {item.title}
                          </a>
                          <i class="iconoir-nav-arrow-down text-xs transition-transform duration-150 group-open/sub:rotate-180 ml-1 shrink-0"></i>
                        </summary>
                        <ul class="mt-0.5 ml-2 space-y-0.5 border-l border-zinc-800 pl-3">
                          {item.items.map((sub) => (
                            <li>
                              <a
                                href={sub.href}
                                class:list={[
                                  'block rounded-lg px-2 py-1.5 transition-colors duration-150',
                                  isActive(sub.href)
                                    ? 'bg-violet-500/15 text-violet-300'
                                    : 'text-zinc-400 hover:bg-zinc-800 hover:text-white',
                                ]}
                              >
                                {sub.title}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </details>
                    </li>
                  );
                }

                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'block rounded-lg px-2 py-1.5 transition-colors duration-150',
                        isActive(item.href)
                          ? 'bg-violet-500/15 text-violet-300'
                          : 'text-zinc-400 hover:bg-zinc-800 hover:text-white',
                      ]}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        </li>
      );
    })}
  </ul>
</nav>
