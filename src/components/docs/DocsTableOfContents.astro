---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav id="toc" class="sticky top-20 py-6 text-sm">
    <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">On this page</p>
    <ul class="space-y-1.5" id="toc-list">
      {filtered.map((heading) => (
        <li class:list={[heading.depth === 3 ? 'ml-3' : '']}>
          <a
            href={`#${heading.slug}`}
            data-toc-slug={heading.slug}
            class="block text-zinc-500 transition-colors duration-150 hover:text-zinc-300 toc-link"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  if (links.length > 0) {
    const slugMap = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      const slug = link.dataset.tocSlug;
      if (slug) slugMap.set(slug, link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('text-violet-400', '!text-violet-400'));
            links.forEach((l) => l.classList.add('text-zinc-500'));
            const link = slugMap.get(entry.target.id);
            if (link) {
              link.classList.remove('text-zinc-500');
              link.classList.add('text-violet-400');
            }
            break;
          }
        }
      },
      { rootMargin: '-80px 0px -70% 0px' }
    );

    document.querySelectorAll('article h2, article h3').forEach((el) => observer.observe(el));
  }
</script>
