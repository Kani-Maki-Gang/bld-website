---
const features = [
  {
    icon: 'iconoir-laptop-dev-mode',
    title: 'Run Anywhere',
    description:
      'Execute pipelines on your local machine, inside Docker containers, or on remote servers via SSH. One tool, every environment.',
  },
  {
    icon: 'iconoir-db',
    title: 'Docker Native',
    description:
      'Pull existing images, build from Dockerfiles, and connect to private registries including Docker Hub and GHCR.',
  },
  {
    icon: 'iconoir-network-right',
    title: 'Parallel Jobs',
    description:
      'Version 2 pipelines support named jobs that run concurrently. Define sequential or parallel execution — you decide.',
  },
  {
    icon: 'iconoir-server',
    title: 'Server Mode',
    description:
      'Deploy bld as a dedicated server for team use. Monitor runs, manage pipelines, and view full history in the built-in Web UI.',
  },
  {
    icon: 'iconoir-clock-rotate-right',
    title: 'Cron Scheduling',
    description:
      'Schedule pipelines to run automatically using cron expressions. Server-managed with complete visibility and control.',
  },
  {
    icon: 'iconoir-github-circle',
    title: 'GitHub Action',
    description:
      'Official bld-action available on the GitHub Marketplace. Integrate bld pipelines seamlessly into any GitHub workflow.',
  },
];
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white">
        Everything you need to automate your pipelines
      </h2>
      <p class="mt-3 text-base text-zinc-400">
        Powerful features with a simple YAML interface.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div class="flex flex-col gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-6 shadow-xl shadow-black/30">
            <div class="flex size-10 items-center justify-center rounded-lg bg-violet-600/10">
              <i class={`${feature.icon} text-lg text-violet-400`} />
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">{feature.title}</h3>
              <p class="mt-1.5 text-sm text-zinc-400">{feature.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
