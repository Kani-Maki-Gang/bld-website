---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bld — Simple and blazingly fast CI/CD',
  description = 'Run pipelines locally, in Docker containers, or on remote servers. Written in Rust.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={import.meta.env.BASE_URL + 'logo.png'} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={import.meta.env.BASE_URL + 'logo_no_bg.png'} type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/gh/iconoir-icons/iconoir@main/css/iconoir.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 font-inter text-white antialiased">
    <div class="bg-grid min-h-screen">
      <slot />
    </div>
  </body>
</html>
