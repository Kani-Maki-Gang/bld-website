---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import SectionCards from '../../components/docs/SectionCards.astro';
import { docsNav, isNavSubSection } from '../../data/docs-nav';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => {
    const slug = entry.id
      .replace(/\.mdx?$/, '')
      .replace(/\/index$/, '');
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const { Content, headings } = await render(entry);

// Detect section index pages (top-level sections or sub-sections with children)
const isSectionIndex =
  docsNav.some((s) => s.slug === slug && s.items.length > 0) ||
  docsNav.some((s) =>
    s.items.some(
      (item) => isNavSubSection(item) && item.slug === slug && item.items.length > 0
    )
  );
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  currentSlug={slug}
>
  <Content />
  {isSectionIndex && <SectionCards slug={slug} />}
</DocsLayout>
